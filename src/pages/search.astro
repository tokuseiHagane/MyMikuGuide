---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/site-utils";
---

<BaseLayout title="Поиск | MyMikuGuide">
  <div class="mb-6">
    <h1 class="text-2xl font-bold m-0">Поиск</h1>
    <p class="text-muted text-sm mt-1 m-0">Полнотекстовый поиск по всем артистам, песням и альбомам</p>
  </div>

  <div class="rounded-2xl bg-panel border border-panel-border p-6">
    <input
      id="search-input"
      type="text"
      placeholder="Введите запрос (минимум 2 символа)..."
      autocomplete="off"
      class="w-full rounded-xl bg-[rgba(15,23,42,0.6)] border border-[rgba(148,163,184,0.18)]
             text-text px-4 py-3 text-base outline-none
             focus:border-accent/40 focus:shadow-[0_0_0_3px_rgba(57,197,187,0.12)]
             transition-all placeholder:text-muted/50"
    />

    <div id="search-status" class="mt-3 text-muted text-sm hidden"></div>

    <div id="search-results" class="mt-4 flex flex-col gap-2"></div>

    <div id="search-fallback" class="hidden text-center py-8">
      <p class="text-muted text-sm">Поисковая база недоступна.</p>
      <p class="text-muted text-xs mt-1">Убедитесь, что browser SQLite snapshot доступен.</p>
    </div>
  </div>

  <script>
    import { searchEntities, isSearchAvailable } from "../lib/client-search";
    import { withBase } from "../lib/site-utils";

    const TYPE_LABELS: Record<string, string> = {
      artist: "Артист",
      song: "Песня",
      album: "Альбом",
    };

    const TYPE_COLORS: Record<string, string> = {
      artist: "bg-emerald-500/15 text-emerald-400 border-emerald-500/25",
      song: "bg-sky-500/15 text-sky-400 border-sky-500/25",
      album: "bg-amber-500/15 text-amber-400 border-amber-500/25",
    };

    const SEGMENT: Record<string, string> = {
      artist: "artists",
      song: "songs",
      album: "albums",
    };

    function entityHref(entityType: string, slug: string) {
      return withBase(`/${SEGMENT[entityType] ?? "artists"}/view/?slug=${encodeURIComponent(slug)}`);
    }

    function escapeHtml(s: string) {
      return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    const input = document.getElementById("search-input") as HTMLInputElement;
    const resultsEl = document.getElementById("search-results")!;
    const statusEl = document.getElementById("search-status")!;
    const fallbackEl = document.getElementById("search-fallback")!;

    let debounceTimer: ReturnType<typeof setTimeout> | null = null;
    let currentQuery = "";

    isSearchAvailable().then((ok) => {
      if (!ok) {
        fallbackEl.classList.remove("hidden");
        input.disabled = true;
        input.placeholder = "Поиск недоступен";
      }
    });

    input.addEventListener("input", () => {
      const q = input.value.trim();
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => runSearch(q), 200);
    });

    async function runSearch(query: string) {
      currentQuery = query;
      if (query.length < 2) {
        resultsEl.innerHTML = "";
        statusEl.classList.add("hidden");
        return;
      }

      statusEl.textContent = "Ищу…";
      statusEl.classList.remove("hidden");

      try {
        const results = await searchEntities(query);
        if (currentQuery !== query) return;

        if (results.length === 0) {
          statusEl.textContent = `По запросу «${query}» ничего не найдено.`;
          resultsEl.innerHTML = "";
          return;
        }

        statusEl.textContent = `Найдено: ${results.length}${results.length >= 40 ? "+" : ""} результатов`;

        resultsEl.innerHTML = results
          .map(
            (r) => `
              <a href="${entityHref(r.entityType, r.slug)}"
                 class="flex items-center gap-3 px-4 py-3 rounded-xl
                        hover:bg-accent/8 transition-colors group">
                <span class="shrink-0 text-[0.65rem] font-bold uppercase tracking-wide
                             px-2 py-0.5 rounded-md border ${TYPE_COLORS[r.entityType] ?? ""}">
                  ${TYPE_LABELS[r.entityType] ?? r.entityType}
                </span>
                <span class="text-sm text-text group-hover:text-accent transition-colors truncate">
                  ${escapeHtml(r.displayName)}
                </span>
              </a>`,
          )
          .join("");
      } catch (err) {
        if (currentQuery !== query) return;
        statusEl.textContent = "Ошибка при поиске. Попробуйте ещё раз.";
        resultsEl.innerHTML = "";
        console.error("Search error:", err);
      }
    }

    input.focus();
  </script>
</BaseLayout>
