---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadYearsIndex } from "../../lib/site-data";
import { withBase } from "../../lib/site-utils";

export async function getStaticPaths() {
  const yearsData = await loadYearsIndex();
  return yearsData.years.map((y) => ({
    params: { year: String(y.year) },
    props: { yearInfo: y },
  }));
}

const { yearInfo } = Astro.props as { yearInfo: { year: number; songs: number; albums: number; total: number } };
---

<BaseLayout title={`${yearInfo.year} год | MyMikuGuide`}>
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
    <div>
      <a href={withBase("/years/")} class="text-sm text-accent hover:text-accent-hover mb-1 inline-block">← Все годы</a>
      <h1 class="text-3xl font-extrabold m-0">{yearInfo.year}</h1>
      <p class="text-muted text-sm mt-1 m-0">{yearInfo.total} записей за этот год</p>
    </div>
    <div class="flex gap-3">
      <div class="rounded-xl bg-panel border border-panel-border px-4 py-3 text-center">
        <span class="text-2xl font-extrabold text-text">{yearInfo.songs.toLocaleString("ru-RU")}</span>
        <span class="block text-xs text-muted mt-0.5">песен</span>
      </div>
      <div class="rounded-xl bg-panel border border-panel-border px-4 py-3 text-center">
        <span class="text-2xl font-extrabold text-text">{yearInfo.albums.toLocaleString("ru-RU")}</span>
        <span class="block text-xs text-muted mt-0.5">альбомов</span>
      </div>
    </div>
  </div>

  <div class="rounded-2xl bg-panel border border-panel-border p-6">
    <p class="text-muted text-sm">
      Для полного списка записей за {yearInfo.year} год воспользуйтесь
      <a href={withBase("/search/")} class="text-accent hover:text-accent-hover">поиском с фильтром по году</a>.
    </p>
  </div>
</BaseLayout>
