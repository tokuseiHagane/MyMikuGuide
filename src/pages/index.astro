---
import EntityCard from "../components/EntityCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadAlbums, loadArtists, loadGraphSummary, loadLastRun, loadNewEntries, loadSongs } from "../lib/site-data";
import { formatDateTime, withBase } from "../lib/site-utils";

const [artists, songs, albums, summary, lastRun, newEntries] = await Promise.all([
  loadArtists(),
  loadSongs(),
  loadAlbums(),
  loadGraphSummary(),
  loadLastRun(),
  loadNewEntries(),
]);

const featuredArtists = artists.slice(0, 6);
const featuredSongs = songs.slice(0, 6);
const featuredAlbums = albums.slice(0, 6);
const highlightedUpdates = [...artists, ...songs, ...albums]
  .sort((left, right) => right.syncedAt.localeCompare(left.syncedAt))
  .slice(0, 4);
---

<BaseLayout title="MyMikuGuide">
  <section class="hero">
    <article class="panel hero__content">
      <div class="hero__eyebrow">VocaDB Snapshot</div>
      <h1 class="hero__headline">MyMikuGuide</h1>
      <p>
        Репозиторий теперь работает как канонический снапшот данных и публикует статический сайт
        по графу Hatsune Miku без live-запросов к API во время просмотра.
      </p>
      <p class="muted">
        Последняя сводка: {summary.artistCount} артистов, {summary.songCount} песен, {summary.albumCount} альбомов.
        Сайт обновлён {formatDateTime(summary.syncedAt)}.
      </p>
      <div class="hero__actions">
        <a class="button-link" href={withBase("/updates/")}>Открыть раздел обновлений</a>
        <a class="button-link button-link--ghost" href={withBase("/artists/")}>Перейти к артистам</a>
      </div>
    </article>

    <aside class="stats-grid">
      <article class="stat-card">
        <p class="muted">Последний sync</p>
        <p class="stat-card__value">{lastRun.mode}</p>
        <p class="muted">Завершён: {formatDateTime(lastRun.finishedAt)}</p>
      </article>
      <article class="stat-card">
        <p class="muted">Сетевой профиль</p>
        <p class="stat-card__value">{lastRun.requestCount}</p>
        <p class="muted">запросов, {lastRun.probeHits} `probe-hit`, {lastRun.fullFetches} full fetch</p>
      </article>
      <article class="stat-card">
        <p class="muted">Нагрузка графа</p>
        <p class="stat-card__value">{lastRun.newEntities}</p>
        <p class="muted">новых сущностей в очереди, {lastRun.limitedEntities} ограничено лимитами</p>
      </article>
    </aside>
  </section>

  <section style="margin-top: 1.25rem;">
    <div class="section-header">
      <div>
        <h2>Недавно синхронизированные сущности</h2>
        <p class="muted">Быстрый обзор того, что трогалось последними прогонами.</p>
      </div>
      <a class="button-link button-link--ghost" href={withBase("/updates/recent/")}>Все обновления</a>
    </div>
    <div class="grid">
      {highlightedUpdates.map((entity) => (
        <EntityCard entity={entity} compact />
      ))}
    </div>
  </section>

  <section style="margin-top: 1.25rem;" class="stack">
    <div class="section-header">
      <div>
        <h2>Избранные артисты</h2>
        <p class="muted">Карточный обзор графа вместо длинного текстового списка.</p>
      </div>
      <a class="button-link button-link--ghost" href={withBase("/artists/")}>Все артисты</a>
    </div>
    <div class="grid">{featuredArtists.map((artist) => <EntityCard entity={artist} />)}</div>
  </section>

  <section style="margin-top: 1.25rem;" class="stack">
    <div class="section-header">
      <div>
        <h2>Избранные песни</h2>
        <p class="muted">Карточки с типом, годом и датой синхронизации.</p>
      </div>
      <a class="button-link button-link--ghost" href={withBase("/songs/")}>Все песни</a>
    </div>
    <div class="grid">{featuredSongs.map((song) => <EntityCard entity={song} />)}</div>
  </section>

  <section style="margin-top: 1.25rem;" class="stack">
    <div class="section-header">
      <div>
        <h2>Избранные альбомы</h2>
        <p class="muted">Обложки, тип альбома и число треков в одном месте.</p>
      </div>
      <a class="button-link button-link--ghost" href={withBase("/albums/")}>Все альбомы</a>
    </div>
    <div class="grid">{featuredAlbums.map((album) => <EntityCard entity={album} />)}</div>
  </section>

  <section style="margin-top: 1.25rem;" class="panel">
    <div class="section-header">
      <div>
        <h2>Новые записи последнего прогона</h2>
        <p class="muted">Появившиеся впервые сущности последнего sync-прохода.</p>
      </div>
      <a class="button-link button-link--ghost" href={withBase("/updates/new/")}>Открыть индекс</a>
    </div>
    <div class="chip-list">
      {newEntries.length === 0 ? <span class="chip">В последнем прогоне новых локальных карточек не появилось.</span> : null}
      {newEntries.slice(0, 12).map((entry) => (
        <a class="chip" href={withBase(entry.url)}>
          {entry.displayName} · {entry.entityType}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
