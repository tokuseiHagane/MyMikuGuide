---
import EntityCard from "../components/EntityCard.astro";
import StatCard from "../components/StatCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  loadGraphSummary,
  loadLastRun,
  loadNewEntries,
  loadRecentlyUpdated,
  loadSummaryPageItems,
} from "../lib/site-data";
import type { AlbumSummary, ArtistSummary, EntitySummary, SongSummary } from "../lib/models";
import { entityHref, formatDateTime, withBase } from "../lib/site-utils";

const [featuredArtists, featuredSongs, featuredAlbums, summary, lastRun, newEntries, recentEntries] = await Promise.all([
  loadSummaryPageItems("artist", 1),
  loadSummaryPageItems("song", 1),
  loadSummaryPageItems("album", 1),
  loadGraphSummary(),
  loadLastRun(),
  loadNewEntries(),
  loadRecentlyUpdated(),
]) as [ArtistSummary[], SongSummary[], AlbumSummary[], Awaited<ReturnType<typeof loadGraphSummary>>, Awaited<ReturnType<typeof loadLastRun>>, EntitySummary[], EntitySummary[]];

const highlightedUpdates: EntitySummary[] = recentEntries.slice(0, 8);
const artistHighlights: ArtistSummary[] = featuredArtists.slice(0, 6);
const songHighlights: SongSummary[] = featuredSongs.slice(0, 6);
const albumHighlights: AlbumSummary[] = featuredAlbums.slice(0, 6);
---

<BaseLayout title="MyMikuGuide">
  <!-- Hero Section -->
  <section class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-bg-alt via-bg to-[rgba(8,47,73,0.6)] border border-panel-border mb-8">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(57,197,187,0.15),transparent_60%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(255,111,145,0.08),transparent_60%)]"></div>
    <div class="relative grid lg:grid-cols-[1.4fr_0.8fr] gap-6 p-8 lg:p-10">
      <div class="flex flex-col justify-center gap-4">
        <span class="text-accent text-xs font-bold uppercase tracking-[0.12em]">VocaDB Snapshot · Живой граф</span>
        <h1 class="text-4xl lg:text-5xl font-extrabold leading-[1.1] tracking-tight m-0">
          <span class="bg-gradient-to-r from-text to-text/80 bg-clip-text text-transparent">MyMiku</span><span class="bg-gradient-to-r from-accent to-accent-strong bg-clip-text text-transparent">Guide</span>
        </h1>
        <p class="text-text/85 text-base lg:text-lg leading-relaxed max-w-xl m-0">
          Статический гид по графу Hatsune Miku из VocaDB — {summary.artistCount.toLocaleString("ru-RU")} артистов,
          {summary.songCount.toLocaleString("ru-RU")} песен, {summary.albumCount.toLocaleString("ru-RU")} альбомов.
        </p>
        <p class="text-muted text-sm m-0">Обновлено {formatDateTime(summary.syncedAt)}</p>
        <div class="flex gap-3 flex-wrap mt-2">
          <a
            href={withBase("/artists/")}
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full font-semibold text-sm
                   bg-gradient-to-r from-accent/25 to-accent-strong/20 border border-accent/30
                   text-text hover:border-accent/50 hover:from-accent/35 hover:to-accent-strong/30 transition-all"
          >
            Каталог артистов
            <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
          </a>
          <a
            href={withBase("/updates/")}
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full font-semibold text-sm
                   bg-panel border border-panel-border text-muted hover:text-text hover:border-accent/25 transition-all"
          >
            Обновления
          </a>
          <a
            href={withBase("/search/")}
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full font-semibold text-sm
                   bg-panel border border-panel-border text-muted hover:text-text hover:border-accent/25 transition-all"
          >
            <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" /></svg>
            Поиск
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-3">
        <StatCard label="Артисты" value={summary.artistCount} />
        <StatCard label="Песни" value={summary.songCount} />
        <StatCard label="Альбомы" value={summary.albumCount} />
      </div>
    </div>
  </section>

  <!-- Recent updates — horizontal scroll -->
  <section class="mb-8">
    <div class="flex items-end justify-between gap-4 mb-4">
      <div>
        <h2 class="text-xl font-bold m-0">Свежее</h2>
        <p class="text-muted text-sm mt-1 m-0">Недавно синхронизированные сущности</p>
      </div>
      <a
        href={withBase("/updates/recent/")}
        class="text-sm text-accent hover:text-accent-hover font-medium transition-colors shrink-0"
      >Все обновления →</a>
    </div>
    <div class="flex gap-4 overflow-x-auto pb-4 -mx-1 px-1 snap-x snap-mandatory scroll-smooth scrollbar-thin">
      {highlightedUpdates.map((entity) => (
        <div class="min-w-[260px] max-w-[300px] snap-start shrink-0">
          <EntityCard entity={entity} compact />
        </div>
      ))}
    </div>
  </section>

  <!-- Featured artists -->
  <section class="mb-8">
    <div class="flex items-end justify-between gap-4 mb-4">
      <div>
        <h2 class="text-xl font-bold m-0">Избранные артисты</h2>
        <p class="text-muted text-sm mt-1 m-0">Карточный обзор графа</p>
      </div>
      <a href={withBase("/artists/")} class="text-sm text-accent hover:text-accent-hover font-medium transition-colors shrink-0">Все артисты →</a>
    </div>
    <div class="card-grid">
      {artistHighlights.map((artist) => <EntityCard entity={artist} />)}
    </div>
  </section>

  <!-- Featured songs -->
  <section class="mb-8">
    <div class="flex items-end justify-between gap-4 mb-4">
      <div>
        <h2 class="text-xl font-bold m-0">Избранные песни</h2>
        <p class="text-muted text-sm mt-1 m-0">Тип, год и дата синхронизации</p>
      </div>
      <a href={withBase("/songs/")} class="text-sm text-accent hover:text-accent-hover font-medium transition-colors shrink-0">Все песни →</a>
    </div>
    <div class="card-grid">
      {songHighlights.map((song) => <EntityCard entity={song} />)}
    </div>
  </section>

  <!-- Featured albums -->
  <section class="mb-8">
    <div class="flex items-end justify-between gap-4 mb-4">
      <div>
        <h2 class="text-xl font-bold m-0">Избранные альбомы</h2>
        <p class="text-muted text-sm mt-1 m-0">Обложки и треки</p>
      </div>
      <a href={withBase("/albums/")} class="text-sm text-accent hover:text-accent-hover font-medium transition-colors shrink-0">Все альбомы →</a>
    </div>
    <div class="card-grid">
      {albumHighlights.map((album) => <EntityCard entity={album} />)}
    </div>
  </section>

  <!-- New entries -->
  <section class="mb-4">
    <div class="rounded-2xl bg-panel border border-panel-border p-6">
      <div class="flex items-end justify-between gap-4 mb-4">
        <div>
          <h2 class="text-lg font-bold m-0">Новые записи последнего прогона</h2>
          <p class="text-muted text-sm mt-1 m-0">Впервые появившиеся сущности</p>
        </div>
        <a href={withBase("/updates/new/")} class="text-sm text-accent hover:text-accent-hover font-medium transition-colors shrink-0">Индекс →</a>
      </div>
      <div class="flex flex-wrap gap-2">
        {newEntries.length === 0 ? (
          <span class="px-3 py-1.5 rounded-full bg-white/6 text-muted text-sm">Новых записей не появилось</span>
        ) : null}
        {newEntries.slice(0, 16).map((entry) => (
          <a
            href={entityHref(entry)}
            class="px-3 py-1.5 rounded-full bg-white/6 text-text text-sm hover:bg-accent/12 hover:text-accent transition-colors"
          >
            {entry.displayName} · <span class="text-muted">{entry.entityType}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
