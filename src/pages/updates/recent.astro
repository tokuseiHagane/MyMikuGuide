---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadRecentlyUpdated } from "../../lib/site-data";
import { entityTypeLabel, formatDateTime, withBase } from "../../lib/site-utils";

const recent = await loadRecentlyUpdated();
---

<BaseLayout title="Недавно обновлялось | MyMikuGuide">
  <section class="panel">
    <div class="section-header">
      <div>
        <h1>Недавно обновлялось</h1>
        <p class="muted">Сущности из локального снапшота, отсортированные по времени последней синхронизации.</p>
      </div>
      <a class="button-link button-link--ghost" href={withBase("/updates/")}>Назад к обзору</a>
    </div>
  </section>

  <section style="margin-top: 1rem;" class="panel stack">
    <ul class="clean">
      {recent.length === 0 ? <li class="muted">Индекс недавно обновлённых сущностей пока пуст.</li> : null}
      {recent.map((entry) => (
        <li class="panel">
          <a href={withBase(entry.url)}>{entry.displayName}</a>
          <div class="muted">
            {entityTypeLabel(entry.entityType)} · {formatDateTime(entry.syncedAt)}
            {typeof entry.upstreamVersion === "number" ? ` · upstream v${entry.upstreamVersion}` : ""}
          </div>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
