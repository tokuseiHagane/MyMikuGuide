---
import EntityCard from "../../components/EntityCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadGraphSummary, loadUpdatedToday } from "../../lib/site-data";
import { withBase } from "../../lib/site-utils";

const MAX_DISPLAY = 500;

const [allTodayEntries, summary] = await Promise.all([
  loadUpdatedToday(),
  loadGraphSummary(),
]);

const todayEntries = allTodayEntries.slice(0, MAX_DISPLAY);
const totalToday = allTodayEntries.length;
const snapshotDay = summary.syncedAt ? new Date(summary.syncedAt).toISOString().slice(0, 10) : "";
---

<BaseLayout title="Обновлено Сегодня | MyMikuGuide">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold m-0">Обновлено сегодня</h1>
      <p class="text-muted text-sm mt-1 m-0">
        Сущности за дату снапшота{snapshotDay ? `: ${snapshotDay}` : ""}
      </p>
    </div>
    <a
      href={withBase("/updates/")}
      class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-full bg-panel border border-panel-border text-muted text-sm
             hover:bg-accent/12 hover:text-text hover:border-accent/25 transition-all"
    >← Обзор</a>
  </div>

  <div class="card-grid card-grid--compact">
    {todayEntries.length === 0 ? (
      <div class="rounded-2xl bg-panel border border-panel-border p-6 text-muted text-sm">На дату последнего снапшота обновлений не найдено.</div>
    ) : null}
    {todayEntries.map((entry) => <EntityCard entity={entry} compact />)}
  </div>
  {totalToday > MAX_DISPLAY ? (
    <p class="text-muted text-sm mt-4">
      Показаны первые {MAX_DISPLAY} из {totalToday.toLocaleString("ru-RU")}.
      Используйте <a href={withBase("/search/")} class="text-accent hover:text-accent-hover">поиск</a> для полного списка.
    </p>
  ) : null}
</BaseLayout>
