---
import EntityCard from "../../components/EntityCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadAlbums, loadArtists, loadGraphSummary, loadSongs } from "../../lib/site-data";
import { withBase } from "../../lib/site-utils";

const [artists, songs, albums, summary] = await Promise.all([
  loadArtists(),
  loadSongs(),
  loadAlbums(),
  loadGraphSummary(),
]);

const snapshotDay = summary.syncedAt ? new Date(summary.syncedAt).toISOString().slice(0, 10) : "";
const todayEntries = [...artists, ...songs, ...albums]
  .filter((entry) => entry.syncedAt.slice(0, 10) === snapshotDay)
  .sort((left, right) => right.syncedAt.localeCompare(left.syncedAt) || left.slug.localeCompare(right.slug));
---

<BaseLayout title="Обновлено Сегодня | MyMikuGuide">
  <section class="panel">
    <div class="section-header">
      <div>
        <h1>Обновлено сегодня</h1>
        <p class="muted">
          Здесь показаны сущности, чья локальная синхронизация пришлась на дату последней сборки снапшота:
          {snapshotDay ? ` ${snapshotDay}` : " дата пока неизвестна"}.
        </p>
      </div>
      <a class="button-link button-link--ghost" href={withBase("/updates/")}>Назад к обзору</a>
    </div>
  </section>

  <section style="margin-top: 1rem;" class="grid">
    {todayEntries.length === 0 ? <div class="panel muted">На дату последнего снапшота обновлений не найдено.</div> : null}
    {todayEntries.map((entry) => <EntityCard entity={entry} compact />)}
  </section>
</BaseLayout>
