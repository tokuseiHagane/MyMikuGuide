---
import EntityCard from "../../components/EntityCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadArtists } from "../../lib/site-data";
import { withBase } from "../../lib/site-utils";

const artists = await loadArtists();
---

<BaseLayout title="Артисты | MyMikuGuide">
  <section class="panel">
    <div class="section-header">
      <div>
        <h1>Артисты</h1>
        <p class="muted">Все синхронизированные артисты из локального снапшота с карточками и изображениями.</p>
      </div>
      <a class="button-link button-link--ghost" href={withBase("/updates/recent/")}>Недавние обновления</a>
    </div>
  </section>

  <section style="margin-top: 1rem;" class="grid grid--wide">
    {artists.length === 0 ? <div class="panel muted">Данные ещё не синхронизированы.</div> : null}
    {artists.map((artist) => <EntityCard entity={artist} />)}
  </section>
</BaseLayout>
