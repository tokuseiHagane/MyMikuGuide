---
import EntityCard from "../../components/EntityCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadSongs } from "../../lib/site-data";
import { withBase } from "../../lib/site-utils";

const songs = await loadSongs();
---

<BaseLayout title="Песни | MyMikuGuide">
  <section class="panel">
    <div class="section-header">
      <div>
        <h1>Песни</h1>
        <p class="muted">Все синхронизированные песни из локального снапшота с визуальными карточками.</p>
      </div>
      <a class="button-link button-link--ghost" href={withBase("/updates/today/")}>Что обновилось сегодня</a>
    </div>
  </section>

  <section style="margin-top: 1rem;" class="grid grid--wide">
    {songs.length === 0 ? <div class="panel muted">Данные ещё не синхронизированы.</div> : null}
    {songs.map((song) => <EntityCard entity={song} />)}
  </section>
</BaseLayout>
