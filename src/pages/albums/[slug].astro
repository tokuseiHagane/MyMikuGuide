---
import EntityCard from "../../components/EntityCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadAlbums, loadArtists, loadSongs } from "../../lib/site-data";
import { buildEntityMap, formatDateTime, linkedEntities, withBase } from "../../lib/site-utils";

export async function getStaticPaths() {
  const albums = await loadAlbums();
  return albums.map((album) => ({
    params: { slug: album.slug },
    props: { album },
  }));
}

const { album } = Astro.props;
const [artists, songs] = await Promise.all([loadArtists(), loadSongs()]);
const artistMap = buildEntityMap(artists);
const songMap = buildEntityMap(songs);
const relatedArtists = linkedEntities(album.artistIds, artistMap).slice(0, 8);
const relatedSongs = linkedEntities(album.songIds, songMap).slice(0, 12);
---

<BaseLayout title={`${album.displayName} | MyMikuGuide`}>
  <section class="panel entity-hero">
    <div class="entity-hero__media">
      {album.primaryImage ? (
        <img src={album.primaryImage} alt={album.displayName} />
      ) : (
        <div class="entity-hero__fallback" aria-hidden="true">{album.displayName.slice(0, 1)}</div>
      )}
    </div>

    <div class="stack">
      <div>
        <div class="chip-list">
          <span class="chip">{album.albumType}</span>
          <span class="chip">{album.year ?? "Без даты"}</span>
          {typeof album.upstreamVersion === "number" ? <span class="chip">upstream v{album.upstreamVersion}</span> : null}
        </div>
        <h1>{album.displayName}</h1>
        {album.additionalNames.length > 0 ? <p class="muted">Другие имена: {album.additionalNames.slice(0, 6).join(", ")}</p> : null}
      </div>

      <ul class="meta-list">
        <li>Локально синхронизирован: {formatDateTime(album.syncedAt)}</li>
        <li>Связанных артистов: {album.artistIds.length}</li>
        <li>Треков: {album.songIds.length}</li>
        <li>Дата релиза: {album.releaseDate ? formatDateTime(album.releaseDate) : "Неизвестно"}</li>
        <li>Каталожный номер: {album.catalogNumber ?? "Не указан"}</li>
      </ul>

      <div class="hero__actions">
        <a class="button-link" href={album.sourceUrl}>Открыть в VocaDB</a>
      </div>
    </div>
  </section>

  <section style="margin-top: 1rem;" class="detail-grid">
    <article class="panel">
      <h2>Внешние ссылки</h2>
      <div class="link-list">
        {album.externalLinks.slice(0, 10).map((link) => (
          <a href={link.url}>
            <span>{link.label}</span>
            <span class="muted">{link.service}</span>
          </a>
        ))}
        {album.externalLinks.length === 0 ? <p class="muted">У этого альбома пока нет сохранённых внешних ссылок.</p> : null}
      </div>
    </article>

    <article class="panel">
      <h2>Трек-лист</h2>
      <div class="link-list">
        {album.tracks.slice(0, 14).map((track) => {
          const linkedSong = songMap.get(track.songId);
          return linkedSong ? (
            <a href={withBase(linkedSong.url)}>
              <span>
                {track.discNumber ? `${track.discNumber}.` : ""}{track.trackNumber ? `${track.trackNumber} ` : ""}{track.name}
              </span>
              <span class="muted">Открыть</span>
            </a>
          ) : (
            <div class="chip">
              {track.discNumber ? `${track.discNumber}.` : ""}{track.trackNumber ? `${track.trackNumber} ` : ""}{track.name}
            </div>
          );
        })}
        {album.tracks.length === 0 ? <p class="muted">Трек-лист для этого альбома не сохранён.</p> : null}
      </div>
    </article>
  </section>

  {relatedArtists.length > 0 ? (
    <section style="margin-top: 1rem;" class="stack">
      <div class="section-header">
        <div>
          <h2>Артисты</h2>
          <p class="muted">Связанные участники и авторы альбома.</p>
        </div>
      </div>
      <div class="grid">{relatedArtists.map((artist) => <EntityCard entity={artist} compact />)}</div>
    </section>
  ) : null}

  {relatedSongs.length > 0 ? (
    <section style="margin-top: 1rem;" class="stack">
      <div class="section-header">
        <div>
          <h2>Песни</h2>
          <p class="muted">Треки альбома, уже присутствующие в локальном снапшоте.</p>
        </div>
      </div>
      <div class="grid">{relatedSongs.map((song) => <EntityCard entity={song} compact />)}</div>
    </section>
  ) : null}
</BaseLayout>
