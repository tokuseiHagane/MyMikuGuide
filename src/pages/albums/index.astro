---
import EntityCard from "../../components/EntityCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadAlbums } from "../../lib/site-data";
import { withBase } from "../../lib/site-utils";

const albums = await loadAlbums();
---

<BaseLayout title="Альбомы | MyMikuGuide">
  <section class="panel">
    <div class="section-header">
      <div>
        <h1>Альбомы</h1>
        <p class="muted">Все синхронизированные альбомы из локального снапшота с обложками и метаданными.</p>
      </div>
      <a class="button-link button-link--ghost" href={withBase("/updates/")}>Служебный раздел</a>
    </div>
  </section>

  <section style="margin-top: 1rem;" class="grid grid--wide">
    {albums.length === 0 ? <div class="panel muted">Данные ещё не синхронизированы.</div> : null}
    {albums.map((album) => <EntityCard entity={album} />)}
  </section>
</BaseLayout>
