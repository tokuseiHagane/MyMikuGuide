---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadAlbums } from "../../lib/site-data";

const albums = await loadAlbums();
---

<BaseLayout title="Альбомы | MyMikuGuide">
  <section class="panel">
    <h1>Альбомы</h1>
    <p class="muted">Все синхронизированные альбомы из локального снапшота.</p>
  </section>

  <section style="margin-top: 1rem;" class="grid">
    {albums.length === 0 ? <div class="panel muted">Данные ещё не синхронизированы.</div> : null}
    {albums.map((album) => (
      <article class="panel">
        <h2><a href={album.url}>{album.displayName}</a></h2>
        <p class="muted">{album.albumType} · {album.year ?? "Без даты"}</p>
        <p class="muted">
          Локально синхронизирован: {new Date(album.syncedAt).toLocaleString("ru-RU")}
          {typeof album.upstreamVersion === "number" ? ` · upstream v${album.upstreamVersion}` : ""}
        </p>
      </article>
    ))}
  </section>
</BaseLayout>
