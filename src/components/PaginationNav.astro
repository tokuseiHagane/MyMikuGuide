---
interface Props {
  currentPage: number;
  lastPage: number;
  url: {
    first?: string;
    prev?: string;
    next?: string;
    last?: string;
  };
}

const { currentPage, lastPage, url } = Astro.props;
---

{lastPage > 1 ? (
  <nav class="flex items-center justify-between gap-4 flex-wrap" aria-label="Пагинация каталога">
    <span class="text-sm text-muted font-medium">
      Стр. <span class="text-text font-bold">{currentPage}</span> из {lastPage}
    </span>
    <div class="flex gap-2 flex-wrap">
      {url.first ? (
        <a class="pagination-btn" href={url.first}>
          <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M15.79 14.77a.75.75 0 01-1.06.02l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.04 1.08L11.832 10l3.938 3.71a.75.75 0 01.02 1.06zm-6 0a.75.75 0 01-1.06.02l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.04 1.08L5.832 10l3.938 3.71a.75.75 0 01.02 1.06z" clip-rule="evenodd" /></svg>
          Первая
        </a>
      ) : null}
      {url.prev ? (
        <a class="pagination-btn" href={url.prev}>
          <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.79 14.77a.75.75 0 01-1.06.02l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 111.04 1.08L8.832 10l3.938 3.71a.75.75 0 01.02 1.06z" clip-rule="evenodd" /></svg>
          Назад
        </a>
      ) : null}
      {url.next ? (
        <a class="pagination-btn" href={url.next}>
          Дальше
          <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
        </a>
      ) : null}
      {url.last ? (
        <a class="pagination-btn" href={url.last}>
          Последняя
          <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4.21 14.77a.75.75 0 01.02-1.06L8.168 10 4.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02zm6 0a.75.75 0 01.02-1.06L14.168 10 10.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
        </a>
      ) : null}
    </div>
  </nav>
) : null}
