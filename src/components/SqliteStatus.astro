<!--
  Floating SQLite download indicator.
  Shows chunk loading progress, cached size, and a reload button.
-->
<div
  id="sqlite-status"
  class="fixed bottom-4 right-4 z-50 max-w-xs w-72
         rounded-2xl bg-panel-strong/95 backdrop-blur-xl
         border border-panel-border shadow-panel
         transition-all duration-300
         translate-y-24 opacity-0 pointer-events-none"
>
  <div class="p-3">
    <!-- Header -->
    <div class="flex items-center justify-between gap-2">
      <div class="flex items-center gap-2 min-w-0">
        <div id="sq-icon" class="shrink-0 w-5 h-5 text-accent">
          <!-- DB icon -->
          <svg viewBox="0 0 20 20" fill="currentColor">
            <path
              fill-rule="evenodd"
              d="M10 1c-3.866 0-7 1.343-7 3v2c0 1.657 3.134 3 7 3s7-1.343 7-3V4c0-1.657-3.134-3-7-3zM3 9.5V12c0 1.657 3.134 3 7 3s7-1.343 7-3V9.5c-1.527 1.09-4.09 1.75-7 1.75S4.527 10.59 3 9.5zM3 15.5V17c0 1.657 3.134 3 7 3s7-1.343 7-3v-1.5c-1.527 1.09-4.09 1.75-7 1.75S4.527 16.59 3 15.5z"
              clip-rule="evenodd"
            />
          </svg>
        </div>
        <span id="sq-title" class="text-xs font-semibold text-text truncate">SQLite база</span>
      </div>
      <div class="flex items-center gap-1 shrink-0">
        <!-- Reload button -->
        <button
          id="sq-reload"
          class="w-6 h-6 flex items-center justify-center rounded-lg
                 text-muted hover:text-accent hover:bg-accent/10 transition-colors"
          title="Перезагрузить базу"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path
              fill-rule="evenodd"
              d="M15.312 11.424a5.5 5.5 0 01-9.201 2.466l-.312-.311V15a.75.75 0 01-1.5 0v-3.5a.75.75 0 01.75-.75H8.5a.75.75 0 010 1.5H7.058l.163.163a4 4 0 006.693-1.793.75.75 0 011.398.554zM4.688 8.576a5.5 5.5 0 019.201-2.466l.312.311V5a.75.75 0 011.5 0v3.5a.75.75 0 01-.75.75H11.5a.75.75 0 010-1.5h1.442l-.163-.163a4 4 0 00-6.693 1.793.75.75 0 01-1.398-.554z"
              clip-rule="evenodd"
            />
          </svg>
        </button>
        <!-- Close button -->
        <button
          id="sq-close"
          class="w-6 h-6 flex items-center justify-center rounded-lg
                 text-muted hover:text-text hover:bg-panel transition-colors"
          title="Скрыть"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Progress bar -->
    <div id="sq-progress-wrap" class="mt-2 hidden">
      <div class="h-1 rounded-full bg-[rgba(148,163,184,0.1)] overflow-hidden">
        <div
          id="sq-bar"
          class="h-full bg-accent/70 rounded-full transition-all duration-500 ease-out"
          style="width: 0%"
        ></div>
      </div>
    </div>

    <!-- Status line -->
    <p id="sq-info" class="text-[0.65rem] text-muted mt-1.5 leading-tight">Ожидание…</p>
  </div>
</div>

<script>
  const root = document.getElementById("sqlite-status")!;
  const titleEl = document.getElementById("sq-title")!;
  const iconEl = document.getElementById("sq-icon")!;
  const infoEl = document.getElementById("sq-info")!;
  const barWrap = document.getElementById("sq-progress-wrap")!;
  const bar = document.getElementById("sq-bar")!;
  const reloadBtn = document.getElementById("sq-reload")!;
  const closeBtn = document.getElementById("sq-close")!;

  let dismissed = false;
  let hasActivity = false;

  function fmt(bytes: number) {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(0)} KB`;
    return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
  }

  function show() {
    if (dismissed) return;
    root.classList.remove("translate-y-24", "opacity-0", "pointer-events-none");
  }

  function hide() {
    root.classList.add("translate-y-24", "opacity-0", "pointer-events-none");
  }

  function updateUI(data: {
    cachedChunks: number;
    cachedBytes: number;
    active: number;
    totalFetched: number;
    error?: boolean;
  }) {
    hasActivity = true;

    if (data.active > 0) {
      titleEl.textContent = "Загрузка SQLite…";
      barWrap.classList.remove("hidden");
      bar.style.width = "100%";
      bar.classList.add("animate-pulse");
      iconEl.classList.add("animate-pulse");
      infoEl.textContent = `Чанков: ${data.cachedChunks} (${fmt(data.cachedBytes)}) · Загружается…`;
    } else if (data.error) {
      titleEl.textContent = "Ошибка загрузки";
      barWrap.classList.add("hidden");
      bar.classList.remove("animate-pulse");
      iconEl.classList.remove("animate-pulse");
      iconEl.classList.add("text-red-400");
      infoEl.textContent = "Не удалось загрузить чанк. Нажмите ↻ для повтора.";
    } else {
      titleEl.textContent = "SQLite база";
      barWrap.classList.remove("hidden");
      bar.style.width = "100%";
      bar.classList.remove("animate-pulse");
      iconEl.classList.remove("animate-pulse", "text-red-400");
      infoEl.textContent = `Загружено: ${data.cachedChunks} чанков (${fmt(data.cachedBytes)})`;
    }

    show();
  }

  // Listen for SW messages
  if ("serviceWorker" in navigator) {
    navigator.serviceWorker.addEventListener("message", (event) => {
      const d = event.data;
      if (d.type === "chunkStart") {
        updateUI({ cachedChunks: 0, cachedBytes: 0, active: d.active, totalFetched: 0 });
        requestStats();
      } else if (d.type === "chunkLoaded") {
        updateUI({
          cachedChunks: d.cachedChunks,
          cachedBytes: d.cachedBytes,
          active: d.active,
          totalFetched: d.totalFetched,
        });
      } else if (d.type === "chunkError") {
        updateUI({
          cachedChunks: 0,
          cachedBytes: 0,
          active: d.active,
          totalFetched: 0,
          error: true,
        });
        requestStats();
      } else if (d.type === "stats") {
        updateUI({
          cachedChunks: d.cachedChunks,
          cachedBytes: d.cachedBytes,
          active: d.activeRequests,
          totalFetched: d.totalFetched,
        });
      } else if (d.type === "cacheCleared") {
        infoEl.textContent = "Кэш очищен. Перезагрузите страницу.";
        titleEl.textContent = "Кэш очищен";
        barWrap.classList.add("hidden");
      }
    });
  }

  function requestStats() {
    navigator.serviceWorker.controller?.postMessage({ type: "getStats" });
  }

  // Reload: clear cache and refresh
  reloadBtn.addEventListener("click", () => {
    if (navigator.serviceWorker.controller) {
      navigator.serviceWorker.controller.postMessage({ type: "clearCache" });
      setTimeout(() => window.location.reload(), 300);
    } else {
      window.location.reload();
    }
  });

  // Close
  closeBtn.addEventListener("click", () => {
    dismissed = true;
    hide();
  });

  // On page load, check if SW has cached data
  if ("serviceWorker" in navigator) {
    navigator.serviceWorker.ready.then(() => {
      setTimeout(requestStats, 500);
    });
  }
</script>
