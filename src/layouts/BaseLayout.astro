---
import { withBase } from "../lib/site-utils";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Автообновляемый статический гид по Hatsune Miku и связанным сущностям из VocaDB." } = Astro.props;
const pathname = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Главная" },
  { href: "/artists/", label: "Артисты" },
  { href: "/songs/", label: "Песни" },
  { href: "/albums/", label: "Альбомы" },
  { href: "/updates/", label: "Обновления" },
  { href: "/legacy/", label: "Архив" },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        color-scheme: dark;
        --bg: #07111f;
        --bg-alt: #0f172a;
        --panel: rgba(15, 23, 42, 0.88);
        --panel-strong: rgba(17, 24, 39, 0.96);
        --panel-border: rgba(148, 163, 184, 0.14);
        --text: #e5eefb;
        --muted: #91a3bf;
        --accent: #5eead4;
        --accent-strong: #22d3ee;
        --shadow: 0 18px 50px rgba(2, 6, 23, 0.35);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, sans-serif;
        background:
          radial-gradient(circle at top, rgba(34, 211, 238, 0.15), transparent 32%),
          linear-gradient(180deg, #020617, var(--bg));
        color: var(--text);
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        color: #a5f3fc;
      }

      header, main, footer {
        width: min(1200px, calc(100% - 2rem));
        margin: 0 auto;
      }

      header {
        padding: 1.5rem 0 1rem;
      }

      .site-shell {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(14px);
        background: rgba(2, 6, 23, 0.7);
        border: 1px solid rgba(148, 163, 184, 0.08);
        border-radius: 20px;
        padding: 1rem 1.25rem;
        box-shadow: var(--shadow);
      }

      .site-brand {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .site-brand__title {
        font-size: 1.05rem;
        font-weight: 800;
        letter-spacing: 0.02em;
      }

      .site-brand__subtitle {
        color: var(--muted);
        font-size: 0.92rem;
      }

      nav {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
      }

      .nav-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.65rem 0.95rem;
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.75);
        border: 1px solid rgba(148, 163, 184, 0.1);
        color: var(--muted);
        transition: 140ms ease;
      }

      .nav-link:hover,
      .nav-link--active {
        background: rgba(34, 211, 238, 0.14);
        color: var(--text);
        border-color: rgba(94, 234, 212, 0.32);
      }

      main {
        padding: 1.25rem 0 3rem;
      }

      footer {
        color: var(--muted);
        padding: 0 0 3rem;
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 24px;
        padding: 1.25rem 1.4rem;
        box-shadow: var(--shadow);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1rem;
      }

      .grid--wide {
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      }

      .hero {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.9fr);
      }

      .hero__content {
        background: linear-gradient(145deg, rgba(15, 23, 42, 0.95), rgba(8, 47, 73, 0.78));
      }

      .hero__eyebrow {
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.78rem;
        font-weight: 700;
      }

      .hero__headline {
        margin: 0.35rem 0 0.75rem;
        font-size: clamp(2rem, 4vw, 3.2rem);
      }

      .hero__actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1.1rem;
      }

      .button-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.85rem 1.15rem;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(94, 234, 212, 0.22), rgba(34, 211, 238, 0.18));
        border: 1px solid rgba(94, 234, 212, 0.28);
        color: var(--text);
        font-weight: 600;
      }

      .button-link--ghost {
        background: rgba(15, 23, 42, 0.66);
        color: var(--muted);
      }

      .stats-grid {
        display: grid;
        gap: 0.75rem;
      }

      .stat-card {
        background: var(--panel-strong);
        border: 1px solid var(--panel-border);
        border-radius: 20px;
        padding: 1rem;
      }

      .stat-card__value {
        font-size: 1.7rem;
        font-weight: 800;
        margin: 0;
      }

      .section-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .section-header h2,
      .section-header h1 {
        margin: 0;
      }

      .section-header p {
        margin: 0.3rem 0 0;
      }

      .muted {
        color: var(--muted);
      }

      h1, h2, h3 {
        line-height: 1.15;
      }

      ul.clean {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      ul.clean li + li {
        margin-top: 0.75rem;
      }

      .entity-card {
        overflow: hidden;
        display: grid;
        grid-template-rows: auto 1fr;
        background: rgba(15, 23, 42, 0.92);
        border: 1px solid var(--panel-border);
        border-radius: 22px;
        box-shadow: var(--shadow);
      }

      .entity-card--compact .entity-card__image {
        aspect-ratio: 16 / 8;
      }

      .entity-card__image {
        display: block;
        aspect-ratio: 16 / 10;
        background: linear-gradient(145deg, rgba(34, 211, 238, 0.16), rgba(15, 23, 42, 0.9));
      }

      .entity-card__image img,
      .entity-card__placeholder {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .entity-card__placeholder {
        display: grid;
        place-items: center;
        font-size: 2.8rem;
        font-weight: 800;
        color: rgba(229, 238, 251, 0.72);
      }

      .entity-card__body {
        padding: 1rem 1rem 1.1rem;
      }

      .entity-card__header {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 0.75rem;
      }

      .entity-card__title {
        margin: 0;
        font-size: 1.1rem;
      }

      .entity-card__description {
        color: var(--muted);
        margin: 0.65rem 0 0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .entity-card__meta {
        list-style: none;
        padding: 0;
        margin: 0.9rem 0 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }

      .entity-card__meta li,
      .entity-pill {
        padding: 0.38rem 0.65rem;
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.1);
        color: var(--muted);
        font-size: 0.86rem;
      }

      .entity-pill--muted {
        background: rgba(34, 211, 238, 0.12);
      }

      .entity-hero {
        display: grid;
        grid-template-columns: minmax(220px, 320px) minmax(0, 1fr);
        gap: 1.25rem;
        align-items: start;
      }

      .entity-hero__media {
        border-radius: 24px;
        overflow: hidden;
        background: linear-gradient(145deg, rgba(34, 211, 238, 0.18), rgba(15, 23, 42, 0.96));
        border: 1px solid var(--panel-border);
        aspect-ratio: 4 / 5;
      }

      .entity-hero__media img,
      .entity-hero__fallback {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .entity-hero__fallback {
        display: grid;
        place-items: center;
        font-size: 4rem;
        font-weight: 800;
        color: rgba(229, 238, 251, 0.72);
      }

      .detail-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      }

      .meta-list {
        display: grid;
        gap: 0.6rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .meta-list li {
        color: var(--muted);
      }

      .chip-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
      }

      .chip {
        display: inline-flex;
        align-items: center;
        padding: 0.42rem 0.72rem;
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.1);
        color: var(--text);
      }

      .link-list {
        display: grid;
        gap: 0.7rem;
      }

      .link-list a {
        display: inline-flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        width: 100%;
        padding: 0.9rem 1rem;
        border-radius: 16px;
        background: rgba(148, 163, 184, 0.08);
        border: 1px solid rgba(148, 163, 184, 0.1);
      }

      .stack {
        display: grid;
        gap: 1rem;
      }

      @media (max-width: 900px) {
        .hero,
        .entity-hero {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="site-shell">
        <div class="site-brand">
          <div>
            <a class="site-brand__title" href={withBase("/")}>MyMikuGuide</a>
            <div class="site-brand__subtitle">Статический гид по Hatsune Miku и связанному графу из VocaDB</div>
          </div>
          <nav>
            {navItems.map((item) => {
              const href = withBase(item.href);
              const active = item.href === "/" ? pathname === href : pathname.startsWith(href);
              return (
                <a class:list={["nav-link", active && "nav-link--active"]} href={href}>
                  {item.label}
                </a>
              );
            })}
          </nav>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Данные синхронизируются из VocaDB и публикуются как статический сайт без выделенного сервера.</p>
    </footer>
  </body>
</html>
