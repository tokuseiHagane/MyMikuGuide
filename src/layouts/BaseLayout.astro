---
import { withBase } from "../lib/site-utils";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Автообновляемый статический гид по Hatsune Miku и связанным сущностям из VocaDB." } = Astro.props;
const pathname = Astro.url.pathname;
const contentSecurityPolicy = [
  "default-src 'self'",
  "base-uri 'self'",
  "form-action 'self'",
  "frame-ancestors 'none'",
  "object-src 'none'",
  "img-src 'self' https: data:",
  "style-src 'self' 'unsafe-inline' https://fonts.googleapis.com",
  "script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'",
  "connect-src 'self'",
  "font-src 'self' https://fonts.gstatic.com https: data:",
  "media-src 'self' https:",
  "worker-src 'self' blob:",
  "frame-src 'self' https://www.youtube.com https://embed.nicovideo.jp",
  "upgrade-insecure-requests",
].join("; ");

interface NavItem {
  href: string;
  label: string;
  children?: { href: string; label: string }[];
}

const navItems: NavItem[] = [
  { href: "/", label: "Главная" },
  {
    href: "/artists/",
    label: "Каталог",
    children: [
      { href: "/artists/", label: "Артисты" },
      { href: "/songs/", label: "Песни" },
      { href: "/albums/", label: "Альбомы" },
    ],
  },
  { href: "/years/", label: "По годам" },
  { href: "/tags/", label: "Теги" },
  { href: "/stats/", label: "Статистика" },
  { href: "/search/", label: "Поиск" },
  { href: "/updates/", label: "Обновления" },
  { href: "/legacy/", label: "Архив" },
];

function isActive(item: NavItem): boolean {
  if (item.href === "/") return pathname === withBase("/") || pathname === withBase("/") + "/";
  const base = withBase(item.href);
  if (pathname.startsWith(base)) return true;
  if (item.children) return item.children.some((c) => pathname.startsWith(withBase(c.href)));
  return false;
}
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta http-equiv="Content-Security-Policy" content={contentSecurityPolicy} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Noto+Sans+JP:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Mobile sidebar overlay -->
    <div
      id="sidebar-overlay"
      class="fixed inset-0 z-40 bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
      aria-hidden="true"
    ></div>

    <!-- Mobile sidebar -->
    <aside
      id="sidebar"
      class="fixed top-0 left-0 z-50 h-full w-72 bg-bg-alt/95 backdrop-blur-xl border-r border-panel-border
             -translate-x-full transition-transform duration-300 lg:hidden overflow-y-auto"
    >
      <div class="flex items-center justify-between p-5 border-b border-panel-border">
        <a href={withBase("/")} class="text-lg font-extrabold tracking-tight text-text">MyMikuGuide</a>
        <button
          id="sidebar-close"
          class="w-9 h-9 flex items-center justify-center rounded-full bg-panel hover:bg-accent/20
                 text-muted hover:text-text transition-colors"
          aria-label="Закрыть меню"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M18 6L6 18M6 6l12 12" />
          </svg>
        </button>
      </div>
      <nav class="p-4 flex flex-col gap-1">
        {navItems.map((item) => (
          <>
            {item.children ? (
              <div class="mt-2">
                <span class="block px-3 py-2 text-xs font-bold uppercase tracking-widest text-accent">{item.label}</span>
                {item.children.map((child) => {
                  const href = withBase(child.href);
                  const active = pathname.startsWith(href);
                  return (
                    <a
                      href={href}
                      class:list={[
                        "block px-3 py-2.5 rounded-xl text-sm transition-colors",
                        active ? "bg-accent/15 text-text font-semibold" : "text-muted hover:bg-panel hover:text-text",
                      ]}
                    >
                      {child.label}
                    </a>
                  );
                })}
              </div>
            ) : (
              <a
                href={withBase(item.href)}
                class:list={[
                  "block px-3 py-2.5 rounded-xl text-sm transition-colors",
                  isActive(item) ? "bg-accent/15 text-text font-semibold" : "text-muted hover:bg-panel hover:text-text",
                ]}
              >
                {item.label}
              </a>
            )}
          </>
        ))}
      </nav>
    </aside>

    <!-- Header -->
    <header
      class="sticky top-0 z-30 w-full backdrop-blur-xl bg-bg/80 border-b border-panel-border/60"
      data-pagefind-ignore="all"
    >
      <div class="w-[min(1200px,calc(100%-2rem))] mx-auto flex items-center justify-between h-16 gap-4">
        <!-- Mobile hamburger -->
        <button
          id="sidebar-open"
          class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-panel/60 hover:bg-accent/20
                 text-muted hover:text-text transition-colors border border-panel-border"
          aria-label="Открыть меню"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M3 12h18M3 6h18M3 18h18" />
          </svg>
        </button>

        <!-- Brand -->
        <a href={withBase("/")} class="flex items-center gap-2.5 shrink-0">
          <span class="text-lg font-extrabold tracking-tight bg-gradient-to-r from-accent to-accent-strong bg-clip-text text-transparent">
            MyMikuGuide
          </span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden lg:flex items-center gap-1 flex-1 justify-center">
          {navItems.map((item) => (
            <>
              {item.children ? (
                <div class="relative group">
                  <button
                    class:list={[
                      "nav-pill",
                      isActive(item) && "nav-pill--active",
                    ]}
                  >
                    {item.label}
                    <svg class="w-3.5 h-3.5 ml-0.5 opacity-50 group-hover:opacity-100 transition-opacity" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                    </svg>
                  </button>
                  <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible
                              group-hover:opacity-100 group-hover:visible transition-all duration-200">
                    <div class="bg-panel-strong/98 backdrop-blur-xl border border-panel-border rounded-2xl p-2 min-w-[160px] shadow-panel">
                      {item.children.map((child) => {
                        const href = withBase(child.href);
                        const active = pathname.startsWith(href);
                        return (
                          <a
                            href={href}
                            class:list={[
                              "block px-3.5 py-2 rounded-xl text-sm whitespace-nowrap transition-colors",
                              active ? "bg-accent/15 text-text font-semibold" : "text-muted hover:bg-accent/10 hover:text-text",
                            ]}
                          >
                            {child.label}
                          </a>
                        );
                      })}
                    </div>
                  </div>
                </div>
              ) : (
                <a
                  href={withBase(item.href)}
                  class:list={[
                    "nav-pill",
                    isActive(item) && "nav-pill--active",
                  ]}
                >
                  {item.label}
                </a>
              )}
            </>
          ))}
        </nav>

        <div class="hidden lg:block w-10"></div>
      </div>
    </header>

    <!-- Main content -->
    <main class="w-[min(1200px,calc(100%-2rem))] mx-auto py-6 pb-12 flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="w-[min(1200px,calc(100%-2rem))] mx-auto pb-10 border-t border-panel-border/40 pt-8" data-pagefind-ignore="all">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <span class="text-sm font-bold text-text/80">MyMikuGuide</span>
          <p class="text-xs text-muted mt-1">Данные синхронизируются из VocaDB и публикуются как статический сайт.</p>
        </div>
        <div class="flex items-center gap-3">
          <a href="https://vocadb.net" class="text-xs text-muted hover:text-accent transition-colors" target="_blank" rel="noopener">VocaDB</a>
          <span class="text-panel-border">·</span>
          <a href="https://github.com/TokuseiHagane/MyMikuGuide" class="text-xs text-muted hover:text-accent transition-colors" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </footer>

    <!-- Sidebar toggle script -->
    <script>
      const sidebar = document.getElementById("sidebar");
      const overlay = document.getElementById("sidebar-overlay");
      const openBtn = document.getElementById("sidebar-open");
      const closeBtn = document.getElementById("sidebar-close");

      function openSidebar() {
        sidebar?.classList.remove("-translate-x-full");
        overlay?.classList.remove("opacity-0", "pointer-events-none");
        overlay?.classList.add("opacity-100", "pointer-events-auto");
      }

      function closeSidebar() {
        sidebar?.classList.add("-translate-x-full");
        overlay?.classList.add("opacity-0", "pointer-events-none");
        overlay?.classList.remove("opacity-100", "pointer-events-auto");
      }

      openBtn?.addEventListener("click", openSidebar);
      closeBtn?.addEventListener("click", closeSidebar);
      overlay?.addEventListener("click", closeSidebar);
    </script>
  </body>
</html>
