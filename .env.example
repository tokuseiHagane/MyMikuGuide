# Local fast sync profile.
# Copy to `.env` if you want to tune your machine differently.

SYNC_CONCURRENCY=6
SYNC_MAX_NEW_ENTITIES_PER_RUN=unlimited
SYNC_ROOT_ARTIST_DISCOGRAPHY_LIMIT=unlimited
SYNC_RELATED_ARTIST_DISCOGRAPHY_LIMIT=unlimited
SYNC_PROBE_TIMEOUT_MS=10000
SYNC_FETCH_TIMEOUT_MS=25000
SYNC_ID_LOOKUP_TIMEOUT_MS=12000
SYNC_RETRY_FAILED_ON_INCREMENTAL=true
SYNC_STORE_RAW=false
SYNC_LOG_PROGRESS=true
SYNC_LOG_PROGRESS_INTERVAL_MS=5000
